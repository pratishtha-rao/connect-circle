generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id                 String        @id @default(cuid())
  authId             String        @unique
  email              String        @unique
  fullName           String
  phone              String?
  role               UserRole      @default(USER)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  onboardingComplete Boolean       @default(false)
  bookings           Booking[]
  organization       Organization?
  worker             Worker?
}

model Organization {
  id          String               @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  address     String?
  logo        String?
  phone       String?
  timezone    String?
  website     String?
  ownerId     String               @unique
  notes       Note[]
  owner       Profile              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workers     OrganizationWorker[]
  services    Service[]
  categories  ServiceCategory[]
  invites     WorkerInvite[]
}

model Worker {
  id            String               @id @default(cuid())
  profileId     String               @unique
  bio           String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  languages     String?
  photo         String?
  availability  Availability[]
  bookings      Booking[]
  notes         Note[]
  organizations OrganizationWorker[]
  profile       Profile              @relation(fields: [profileId], references: [id])
  services      WorkerService[]
}

model OrganizationWorker {
  id             String       @id @default(cuid())
  organizationId String
  workerId       String
  verified       Boolean      @default(false)
  primaryOrg     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  worker         Worker       @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([organizationId, workerId])
}

model WorkerInvite {
  id             String       @id @default(cuid())
  email          String
  fullName       String
  organizationId String
  token          String       @unique
  accepted       Boolean      @default(false)
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model WorkerService {
  id        String  @id @default(cuid())
  workerId  String
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  worker    Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, serviceId])
}

model ServiceCategory {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  services       Service[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Service {
  id             String           @id @default(cuid())
  title          String
  description    String?
  price          Float
  duration       Int
  organizationId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  categoryId     String?
  bookings       Booking[]
  notes          Note[]
  category       ServiceCategory? @relation(fields: [categoryId], references: [id])
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplies       Supply[]
  workers        WorkerService[]
}

model Supply {
  id        String  @id @default(cuid())
  name      String
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Availability {
  id        String @id @default(cuid())
  workerId  String
  dayOfWeek Int
  startTime String
  endTime   String
  worker    Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model Booking {
  id                 String        @id @default(cuid())
  date               DateTime
  status             BookingStatus @default(PENDING)
  notes              String?
  profileId          String
  workerId           String?
  serviceId          String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  cancellationReason String?
  deletedAt          DateTime?
  deletedReason      String?
  cancelledAt        DateTime?
  organizationNotes  String?
  profile            Profile       @relation(fields: [profileId], references: [id])
  service            Service       @relation(fields: [serviceId], references: [id])
  worker             Worker?       @relation(fields: [workerId], references: [id])
  payment            Payment?
}

model Payment {
  id                  String        @id @default(cuid())
  bookingId           String        @unique
  amount              Float
  stripePaymentIntent String?
  status              PaymentStatus @default(PENDING)
  refundedAmount      Float?
  paidAt              DateTime?
  booking             Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Note {
  id             String        @id @default(cuid())
  text           String
  organizationId String?
  workerId       String?
  serviceId      String?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service        Service?      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  worker         Worker?       @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

enum UserRole {
  USER
  WORKER
  ORG_ADMIN
  SUPER_ADMIN
  INDEPENDENT_WORKER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  PENDING_APPROVAL
  PENDING_PAYMENT
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}
